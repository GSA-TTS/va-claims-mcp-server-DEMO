# VA OAuth credentials (from developer.va.gov)
VA_CLIENT_ID=your_client_id_here
VA_CLIENT_SECRET=your_client_secret_here

# Server base URL (for OAuth redirect)
BASE_URL=http://localhost:8000

# VA API base URL (defaults to sandbox)
VA_API_BASE=https://sandbox-api.va.gov/services/claims/v2

# VA OAuth base URL (defaults to sandbox)
VA_OAUTH_BASE=https://sandbox-api.va.gov/oauth2
